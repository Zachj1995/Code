function buildComparisonSheet_(ss, header, rows) {
  let sh = ss.getSheetByName(SHEET_COMPARISON);
  if (sh) ss.deleteSheet(sh);
  sh = ss.insertSheet(SHEET_COMPARISON);

  const data = [header];
  for (const row of rows) data.push(header.map(h => row[h] !== undefined ? row[h] : ''));
  const rng = sh.getRange(1, 1, data.length, header.length);
  rng.setValues(data);

  sh.setFrozenRows(1);
  sh.autoResizeColumns(1, header.length);
  sh.getRange(1, 1, sh.getLastRow(), sh.getLastColumn()).createFilter();
}

function applyFormatting_(ss, header) {
  const sh = ss.getSheetByName(SHEET_COMPARISON);
  if (!sh) return;
  const rows = sh.getLastRow(), cols = sh.getLastColumn();
  if (rows < 2) return;

  const colIndex = {};
  const headerValues = sh.getRange(1, 1, 1, cols).getValues()[0];
  headerValues.forEach((h, i) => { colIndex[h] = i + 1; });

  const PAIRS = [
    ['Email_Bob','Email_Gusto','Email_Match'],
    ['First_Bob','First_Gusto','First_Match'],
    ['Last_Bob','Last_Gusto','Last_Match'],
    ['DOB_Bob','DOB_Gusto','DOB_Match'],
    ['Status_Bob','Status_Gusto','Status_Match'],
    ['TermDate_Bob','EndDate_Gusto','TermDate_Match'],
    ['Type_Bob','Type_Gusto','Type_Match'],
    ['Amount_Bob','Amount_Gusto','Amount_Match'],
    ['EffDate_Bob','EffDate_Gusto','EffDate_Match']
  ];

  const rules = [];

  // Red for No
  for (const [bobCol, gusCol, matchCol] of PAIRS) {
    const bCol = colIndex[bobCol], gCol = colIndex[gusCol], mCol = colIndex[matchCol];
    if (!bCol || !gCol || !mCol) continue;

    const range = sh.getRange(2, Math.min(bCol, gCol), rows - 1, Math.abs(gCol - bCol) + 1);
    const formulaNo = `=$${columnLetter_(mCol)}2="No"`;
    rules.push(
      SpreadsheetApp.newConditionalFormatRule()
        .setRanges([range])
        .whenFormulaSatisfied(formulaNo)
        .setBackground('#f4c7c3')
        .build()
    );
  }

  // Amber entire row if Review_Flag indicates review/ambiguous
  const rfCol = colIndex['Review_Flag'];
  if (rfCol) {
    const rowRange = sh.getRange(2, 1, rows - 1, cols);
    const formulaAmber = `=OR($${columnLetter_(rfCol)}2="Needs review",$${columnLetter_(rfCol)}2="Ambiguous")`;
    rules.push(
      SpreadsheetApp.newConditionalFormatRule()
        .setRanges([rowRange])
        .whenFormulaSatisfied(formulaAmber)
        .setBackground('#fce8b2')
        .build()
    );
  }

  sh.setConditionalFormatRules(rules);
}
