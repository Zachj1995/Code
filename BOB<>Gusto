const SHEET_BOB = 'Bob';
const SHEET_GUSTO = 'Gusto';
const SHEET_COMPARISON = 'Comparison';

const TYPE_SALARY = 'Salary/No overtime';
const TYPE_HOURLY = 'Paid by the hour';

const HEADER_ALIASES = {
  // shared
  email: ['email', 'work email address', 'work email', 'employee email', 'company email'],
  firstName: ['first name', 'firstname', 'first', 'f'],
  lastName: ['last name', 'lastname', 'last', 'l', 'last name)'],
  dob: ['date of birth', 'dob', 'birth date', 'birthdate'],

  // address
  address: ['full address', 'address', 'street address', 'home address', 'home street address'],

  // hibob (Bob)
  lifecycleStatus: ['lifecycle status', 'employment lifecycle status', 'status (hibob)'],
  lastDayOfWork: ['last day of work', 'termination date', 'last working day', 'employment end date'],
  flsaCode: ['flsa code', 'flsa', 'flsa status', 'flsa_code'],
  baseSalary: ['base salary', 'salary', 'base pay', 'annual base salary'],
  baseCurrency: ['base salary currency', 'currency', 'salary currency', 'currency code'],
  effDate: ['base salary/effective date', 'base salary effective date', 'effective date'],

  // gusto
  employmentStatus: ['employment status', 'status', 'employee status'],
  employeeType: ['employee type', 'employment type', 'job compensation type', 'compensation type', 'pay type', 'employee_type'],
  endDate: ['employee end date', 'end date', 'termination date'],
  compRateString: ['job compensation rate', 'compensation rate', 'rate', 'comp rate', 'pay rate'],
  compEffectiveDate: ['job compensation effective date', 'compensation effective date', 'comp effective date']
};

const FLSA_TO_GUSTO = {
  'exempt': TYPE_SALARY,
  'non-exempt': TYPE_HOURLY
};

// U.S. detection helpers

function isGustoEmployed_(g) {
  if (!g) return false;
  const status = normalizeStatusGusto_(g.employmentStatus || '');
  if (status === 'Active') return true;

  // Fall back to employee type signals
  const t = String(g.employeeType || g.employee_type || '').toLowerCase();
  return (
    /\bfull[\s-]?time\b/.test(t) ||
    /\bseasonal\b/.test(t) ||
    /\bpart\s*[- ]?time\s*eligible\b/.test(t)
  );
}

